{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://sanunjara-api-production.up.railway.app/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://sanunjara-api-production.up.railway.app/uploads/$1" },
    { "source": "/images/cards/(.*)", "destination": "https://sanunjara-api-production.up.railway.app/images/cards/$1" },
    { "source": "/images/maps/(.*)", "destination": "https://sanunjara-api-production.up.railway.app/images/maps/$1" },
    { "source": "/biographies/(.*)", "destination": "https://sanunjara-api-production.up.railway.app/biographies/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:js|css|woff2?|png|jpg|jpeg|gif|svg|webp|ico|ogg|mp3|pdf|txt|xml))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
