PORT=5050
MONGODB_URI=mongodb://127.0.0.1:27017/sanun_jara_elite
JWT_SECRET=change_me_in_production
CORS_ORIGIN=http://localhost:8080,http://localhost:8081

# One admin account (seeded on server start if empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# Uploads served at /uploads
UPLOAD_DIR=uploads

# Email — form submissions are saved to the database; email sends when configured
# Railway Hobby/Free blocks SMTP (ports 465/587). Use Resend on Railway, or SMTP locally / Railway Pro.
RESEND_API_KEY=
RESEND_FROM=info@sanunjara.com
RESEND_TO=info@sanunjara.com

# SMTP (works locally and on Railway Pro plan)
# After creating info@sanunjara.com at your host, paste credentials here
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=info@sanunjara.com
SMTP_PASS=
SMTP_FROM=info@sanunjara.com
SMTP_TO=info@sanunjara.com
